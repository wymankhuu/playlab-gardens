# Playlab Gardens — Environment Variables
# Copy this file to .env and fill in your values.
# See DATA.md for how these are used in the data pipeline.

# ---- Notion (required for export script + API) ----
NOTION_API_KEY=                  # Notion integration token (starts with ntn_)
NOTION_MASTER_DB_ID=             # Showcase Apps Master database ID
NOTION_PARENT_PAGE_ID=           # Playlab Community Gardens page ID
NOTION_DATABASE_ID=              # Original raw data database ID (5,400 entries)
NOTION_OVERRIDES_DB_ID=          # Manual overrides database ID

# ---- Admin ----
ADMIN_PASSWORD=                  # Password for the admin edit panel in the drawer

# ---- Upstash Redis (optional — powers star counts) ----
KV_REST_API_URL=                 # Upstash Redis REST URL
KV_REST_API_TOKEN=               # Upstash Redis REST token

# ---- Slack (optional — notification on app submission) ----
SLACK_WEBHOOK_URL=               # Slack incoming webhook for submission alerts
